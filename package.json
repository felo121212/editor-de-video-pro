{
  "name": "editor-de-video-pro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n API,WEB,WORKER -c magenta,cyan,green \"tsx watch src/server/server.ts\" \"vite --host 0.0.0.0\" \"tsx watch src/worker/worker.ts\"",
    "dev:api": "tsx watch src/server/server.ts",
    "dev:web": "vite --host 0.0.0.0",
    "dev:worker": "tsx watch src/worker/worker.ts",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node dist/start.js",
    "worker": "node dist/worker/worker.js",
    "migrate": "tsx src/server/db/migrate.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.2.0",
    "mysql2": "^3.12.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
